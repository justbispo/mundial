{
    "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
    "files": {
        "includes": ["**", "!icons/*.svg"]
    },
    "overrides": [
        {
            "includes": ["data.js"],
            "linter": {
                "rules": {
                    "correctness": {
                        "noUnusedVariables": "off"
                    }
                }
            }
        }
    ],
    "html": {
        "formatter": {
            "enabled": true
        }
    },
    "json": {
        "formatter": {
            "indentWidth": 4
        }
    },
    "formatter": {
        "indentStyle": "space"
    }
}
